---
import { Icon } from "astro-icon/components";
import WidgetLayout from "@/components/common/WidgetLayout.astro";
import { wakenConfig } from "@/config/wakenConfig";

interface Props {
	class?: string;
	style?: string;
}
const { class: className, style } = Astro.props;

// 用一个稳定 id 方便客户端脚本定位与缓存破坏
const widgetDomId = `waken-status-${Math.random().toString(36).slice(2, 9)}`;
const initialSrc = wakenConfig.statusCardUrl;
---

<WidgetLayout
	id={widgetDomId}
	class={className}
	style={style}
	name={wakenConfig.nowWidget.title}
>
	<a
		href={wakenConfig.url}
		target="_blank"
		rel="noopener noreferrer"
		aria-label="在 Waken-wa 查看完整状态"
		class="block w-full overflow-hidden rounded-xl transition active:scale-[0.98] hover:opacity-95"
	>
		<img
			data-waken-status
			data-original-src={initialSrc}
			data-hide-on-error={String(wakenConfig.nowWidget.hideOnError)}
			src={initialSrc}
			alt="Waken-wa 当前状态卡片"
			loading="lazy"
			decoding="async"
			class="waken-status-img w-full h-auto block rounded-xl"
		/>
	</a>
	<div class="flex items-center justify-end gap-1 mt-2 text-xs text-neutral-500 dark:text-neutral-400">
		<Icon name={wakenConfig.navIcon} class="text-[0.9rem]" />
		<span>via {wakenConfig.navName}</span>
	</div>
</WidgetLayout>

<script is:inline define:vars={{ refreshIntervalMs: wakenConfig.nowWidget.refreshIntervalMs }}>
	(function bindWakenStatusRefresh() {
		function bust(url) {
			// 给原 URL 追加/覆盖一个 _ts 时间戳参数，确保 img 重新请求
			try {
				const u = new URL(url, window.location.href);
				u.searchParams.set("_ts", String(Date.now()));
				return u.toString();
			} catch (e) {
				const sep = url.indexOf("?") >= 0 ? "&" : "?";
				return url + sep + "_ts=" + Date.now();
			}
		}

		function refreshAll() {
			const imgs = document.querySelectorAll("img[data-waken-status]");
			imgs.forEach((img) => {
				const original = img.getAttribute("data-original-src");
				if (!original) return;
				img.src = bust(original);
			});
		}

		function bindErrorHide() {
			document.querySelectorAll("img[data-waken-status]").forEach((img) => {
				if (img.dataset.errorBound === "1") return;
				img.dataset.errorBound = "1";
				img.addEventListener("error", () => {
					if (img.dataset.hideOnError === "true") {
						// 隐藏整张卡片（WidgetLayout 是最近的 widget-layout 祖先）
						const card = img.closest("widget-layout");
						if (card) card.style.display = "none";
					} else {
						img.style.opacity = "0.4";
					}
				});
			});
		}

		function init() {
			bindErrorHide();
			refreshAll();
		}

		// 首次绑定
		init();

		// 兜底定时刷新（只在页面长时间停留时生效）
		if (refreshIntervalMs && refreshIntervalMs >= 5000) {
			setInterval(refreshAll, refreshIntervalMs);
		}

		// 配合 swup 页面切换：每次换页都重拉 + 重新绑定 error 监听
		document.addEventListener("swup:contentReplaced", () => {
			setTimeout(init, 50);
		});
	})();
</script>
